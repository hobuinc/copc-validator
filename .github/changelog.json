{
  "categories": [
    {
      "title": "## Features",
      "labels": ["feature", "enhancement"]
    },
    {
      "title": "## Fixes",
      "labels": ["fix", "bugfix", "bug"]
    },
    {
      "title": "## Maintenance",
      "labels": ["ci", "chore", "maintenance", "dependencies"]
    },
    {
      "title": "## Uncategorized",
      "labels": []
    }
  ],
  "ignore_labels": [
    "ignore"
  ],
  "sort": "ASC",
  "template": "#{{CHANGELOG}}",
  "pr_template": "- #{{TITLE}} (##{{NUMBER}} by @#{{AUTHOR}})",
  "label_extractor": [
    {
      "pattern": "(.) (.+)",
      "target": "$1"
    }
  ],
  "duplicate_filter": {
    "pattern": "\\[ABC-....\\]",
    "on_property": "title",
    "method": "match"
  }
}
